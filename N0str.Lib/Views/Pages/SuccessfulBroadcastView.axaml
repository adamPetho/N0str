<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             xmlns:vm="clr-namespace:N0str.ViewModels.Pages"
             x:DataType="vm:SuccessfulBroadcastViewModel"
             x:Class="N0str.Views.Pages.SuccessfulBroadcastView"
             Background="Transparent">
  <StackPanel VerticalAlignment="Center"
              HorizontalAlignment="Center"
              Spacing="16"
              Margin="32">

    <Image Source="avares://N0str.Desktop/Assets/checkmark.png"
           Width="64"
           Height="64"
           HorizontalAlignment="Center"/>

    <StackPanel Spacing="4" HorizontalAlignment="Center">
      <TextBlock Text="Event Published"
                 FontSize="16"
                 FontWeight="SemiBold"
                 Foreground="#F2F2F2"
                 HorizontalAlignment="Center"/>
      <TextBlock Text="Successfully broadcast to relays."
                 FontSize="12"
                 FontWeight="Light"
                 Foreground="#666666"
                 HorizontalAlignment="Center"/>
    </StackPanel>

  </StackPanel>
</UserControl>
