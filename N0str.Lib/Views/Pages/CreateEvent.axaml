<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:N0str.ViewModels.Pages"
             x:DataType="vm:CreateEventViewModel"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="N0str.Views.Pages.CreateEvent">

    <UserControl.Styles>
        <Style Selector="TextBox#ContentInput /template/ Border#PART_BorderElement">
          <Setter Property="Background" Value="#242424"/>
          <Setter Property="BorderThickness" Value="0"/>
          <Setter Property="CornerRadius" Value="8"/>
        </Style>
        <Style Selector="TextBox#ContentInput:focus /template/ Border#PART_BorderElement">
          <Setter Property="Background" Value="#242424"/>
          <Setter Property="BorderThickness" Value="0"/>
        </Style>
        <Style Selector="TextBox#ContentInput:pointerover /template/ Border#PART_BorderElement">
          <Setter Property="Background" Value="#242424"/>
          <Setter Property="BorderThickness" Value="0"/>
        </Style>
        <Style Selector="TextBox#ContentInput:disabled /template/ Border#PART_BorderElement">
          <Setter Property="Background" Value="#242424"/>
          <Setter Property="BorderThickness" Value="0"/>
        </Style>

        <Style Selector="TextBox#KindInput /template/ Border#PART_BorderElement">
          <Setter Property="Background" Value="#242424"/>
          <Setter Property="BorderThickness" Value="0"/>
          <Setter Property="CornerRadius" Value="8"/>
        </Style>
        <Style Selector="TextBox#KindInput:focus /template/ Border#PART_BorderElement">
          <Setter Property="Background" Value="#242424"/>
          <Setter Property="BorderThickness" Value="0"/>
        </Style>
        <Style Selector="TextBox#KindInput:pointerover /template/ Border#PART_BorderElement">
          <Setter Property="Background" Value="#242424"/>
          <Setter Property="BorderThickness" Value="0"/>
        </Style>
</UserControl.Styles>

  <ScrollViewer>
    <StackPanel Margin="40,32" Spacing="12" MaxWidth="580" HorizontalAlignment="Center">

      <!-- Header -->
      <StackPanel Spacing="4" Margin="2,0,0,16">
        <TextBlock Text="Create Event"
                   FontSize="22"
                   FontWeight="SemiBold"
                   Foreground="#F2F2F2"
                   LetterSpacing="-0.4"/>
        <TextBlock Text="Compose and publish a new Nostr event"
                   FontSize="13"
                   FontWeight="Light"
                   Foreground="#666666"/>
      </StackPanel>

      <!-- Content Card -->
      <Border Background="#1C1C1C"
              BorderBrush="#2A2A2A"
              BorderThickness="1"
              CornerRadius="14"
              Padding="22,20">
        <StackPanel Spacing="10">
          <StackPanel Orientation="Horizontal" Spacing="7">
            <Ellipse Width="5" Height="5" Fill="#7B68EE" VerticalAlignment="Center"/>
            <TextBlock Text="CONTENT"
                       FontSize="11"
                       FontWeight="SemiBold"
                       Foreground="#555555"
                       LetterSpacing="1.2"/>
          </StackPanel>
              <TextBox Name="ContentInput"
             Text="{Binding Content}"
             AcceptsReturn="True"
             TextWrapping="Wrap"
             Height="120"
             Watermark="What's on your mind?"
             Background="#242424"
             Foreground="#E0E0E0"
             BorderThickness="0"
             Padding="12"
             FontSize="14"
             FontWeight="Light"
             CaretBrush="#7B68EE"/>
        </StackPanel>
      </Border>

      <!-- Kind Card -->
      <Border Background="#1C1C1C"
              BorderBrush="#2A2A2A"
              BorderThickness="1"
              CornerRadius="14"
              Padding="22,20">
        <StackPanel Spacing="10">
          <StackPanel Orientation="Horizontal" Spacing="7">
            <Ellipse Width="5" Height="5" Fill="#7B68EE" VerticalAlignment="Center"/>
            <TextBlock Text="KIND"
                       FontSize="11"
                       FontWeight="SemiBold"
                       Foreground="#555555"
                       LetterSpacing="1.2"/>
          </StackPanel>

          <TextBox Name="KindInput"
                   Text="{Binding KindText}"
                   Watermark="e.g. 1"
                   Background="#242424"
                   Foreground="#E0E0E0"
                   BorderThickness="0"
                   CornerRadius="8"
                   Padding="12"
                   FontSize="14"
                   FontWeight="Light"
                   CaretBrush="#7B68EE"/>
        </StackPanel>
      </Border>

      <!-- Tags Card -->
      <Border Background="#1C1C1C"
              BorderBrush="#2A2A2A"
              BorderThickness="1"
              CornerRadius="14"
              Padding="22,20">
        <StackPanel Spacing="0">

          <!-- Tags Header Toggle -->
          <Button Command="{Binding ToggleTagsCommand}"
                  Background="Transparent"
                  BorderThickness="0"
                  Padding="0"
                  HorizontalAlignment="Stretch"
                  HorizontalContentAlignment="Stretch">
            <Grid ColumnDefinitions="Auto,Auto,*,Auto">
              <Ellipse Grid.Column="0" Width="5" Height="5" Fill="#7B68EE" VerticalAlignment="Center"/>
              <TextBlock Grid.Column="1"
                         Text="TAGS"
                         FontSize="11"
                         FontWeight="SemiBold"
                         Foreground="#555555"
                         LetterSpacing="1.2"
                         VerticalAlignment="Center"
                         Margin="7,0,0,0"/>
              <Border Grid.Column="2"
                      Background="#252525"
                      BorderBrush="#2E2E2E"
                      BorderThickness="1"
                      CornerRadius="20"
                      Padding="9,2"
                      HorizontalAlignment="Left"
                      Margin="10,0,0,0">
                <TextBlock Text="{Binding Tags.Count}"
                           FontSize="11"
                           Foreground="#666666"/>
              </Border>
              <TextBlock Grid.Column="3"
                         Text="{Binding TagsExpanded, Converter={StaticResource BoolToChevronConverter}}"
                         FontSize="13"
                         Foreground="#444444"
                         VerticalAlignment="Center"/>
            </Grid>
          </Button>

          <!-- Expanded Content -->
          <StackPanel IsVisible="{Binding TagsExpanded}" Spacing="8" Margin="0,16,0,0">
            <Rectangle Height="1" Fill="#232323" Margin="0,0,0,4"/>

            <!-- Column Labels -->
            <Grid ColumnDefinitions="*,*,28">
              <TextBlock Grid.Column="0"
                         Text="IDENTIFIER"
                         FontSize="10"
                         Foreground="#3A3A3A"
                         FontWeight="SemiBold"
                         LetterSpacing="1"
                         Margin="4,0,0,0"/>
              <TextBlock Grid.Column="1"
                         Text="VALUE"
                         FontSize="10"
                         Foreground="#3A3A3A"
                         FontWeight="SemiBold"
                         LetterSpacing="1"
                         Margin="4,0,0,0"/>
            </Grid>

            <!-- Tag Rows -->
            <ItemsControl ItemsSource="{Binding Tags}">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Grid ColumnDefinitions="*,*,Auto" Margin="0,0,0,8">
                    <TextBox Grid.Column="0"
                             Text="{Binding Identifier}"
                             Watermark="Identifier"
                             Background="#171717"
                             Foreground="#D0D0D0"
                             BorderBrush="#272727"
                             BorderThickness="1"
                             CornerRadius="8"
                             Padding="12,9"
                             FontSize="12"
                             Margin="0,0,8,0"
                             CaretBrush="#7B68EE"/>
                    <TextBox Grid.Column="1"
                             Text="{Binding Data}"
                             Watermark="Data"
                             Background="#171717"
                             Foreground="#D0D0D0"
                             BorderBrush="#272727"
                             BorderThickness="1"
                             CornerRadius="8"
                             Padding="12,9"
                             FontSize="12"
                             Margin="0,0,8,0"
                             CaretBrush="#7B68EE"/>
                    <Button Grid.Column="2"
                            Command="{Binding $parent[UserControl].DataContext.RemoveTagCommand}"
                            CommandParameter="{Binding}"
                            Background="Transparent"
                            BorderThickness="0"
                            Foreground="#3A3A3A"
                            Padding="6,4"
                            Content="✕"
                            FontSize="14"
                            VerticalAlignment="Center"/>
                  </Grid>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Add Tag -->
            <Button Command="{Binding AddTagCommand}"
                    Background="Transparent"
                    BorderBrush="#2E2E2E"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="14,8"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Left">
              <StackPanel Orientation="Horizontal" Spacing="7">
                <TextBlock Text="+"
                           FontSize="16"
                           Foreground="#7B68EE"
                           VerticalAlignment="Center"/>
                <TextBlock Text="Add tag"
                           FontSize="12"
                           Foreground="#555555"
                           VerticalAlignment="Center"/>
              </StackPanel>
            </Button>
          </StackPanel>
        </StackPanel>
      </Border>

      <!-- Submit & Back --> 
      <Grid ColumnDefinitions="*, *">
          <Button Command="{Binding NavigateBack}"
                  Grid.Column="0"
                  HorizontalAlignment="Stretch"
                  HorizontalContentAlignment="Center"
                  Background="#7B68EE"
                  Foreground="#FFFFFF"
                  BorderThickness="0"
                  CornerRadius="12"
                  Padding="0,15"
                  FontSize="14"
                  FontWeight="SemiBold"
                  Content="Cancel"
                  Margin="0,4,4,0"/>

          <Button Command="{Binding SignAndPublishCommand}"
                  Grid.Column="1"
                  HorizontalAlignment="Stretch"
                  HorizontalContentAlignment="Center"
                  Background="#7B68EE"
                  Foreground="#FFFFFF"
                  BorderThickness="0"
                  CornerRadius="12"
                  Padding="0,15"
                  FontSize="14"
                  FontWeight="SemiBold"
                  Content="Sign &amp; Publish"
                  Margin="0,4,0,0"/>
      </Grid>
    </StackPanel>
  </ScrollViewer>
</UserControl>
