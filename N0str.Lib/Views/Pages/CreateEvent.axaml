<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:N0str.ViewModels.Pages"
             x:DataType="vm:CreateEventViewModel"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="N0str.Views.Pages.CreateEvent">
  <ScrollViewer>
    <StackPanel Margin="40" Spacing="24" MaxWidth="600" HorizontalAlignment="Center">

      <!-- Header -->
      <StackPanel Spacing="4">
        <TextBlock Text="Create Event"
                   FontSize="24"
                   FontWeight="SemiBold"
                   Foreground="#F0F0F0"/>
        <TextBlock Text="Compose and publish a new Nostr event"
                   FontSize="13"
                   Foreground="#888888"/>
      </StackPanel>

      <!-- Content -->
      <StackPanel Spacing="8">
        <TextBlock Text="Content"
                   FontSize="13"
                   FontWeight="SemiBold"
                   Foreground="#AAAAAA"/>
        <TextBox Text="{Binding Content}"
                 AcceptsReturn="True"
                 TextWrapping="Wrap"
                 Height="120"
                 Watermark="What's on your mind?"
                 Background="#2B2B2B"
                 Foreground="#F0F0F0"
                 BorderBrush="#3D3D3D"
                 BorderThickness="1"
                 Padding="12"
                 CornerRadius="8"
                 CaretBrush="#AAAAAA"/>
      </StackPanel>

      <!-- Kind -->
      <StackPanel Spacing="8">
        <TextBlock Text="Kind"
                   FontSize="13"
                   FontWeight="SemiBold"
                   Foreground="#AAAAAA"/>
        <NumericUpDown Value="{Binding Kind}"
                       Minimum="0"
                       Maximum="65535"
                       Increment="1"
                       FormatString="0"
                       Watermark="e.g. 1"
                       Background="#2B2B2B"
                       Foreground="#F0F0F0"
                       BorderBrush="#3D3D3D"
                       BorderThickness="1"
                       CornerRadius="8"
                       Padding="8"/>
      </StackPanel>

      <!-- Tags (Collapsible) -->
      <Border Background="#232323"
              BorderBrush="#3D3D3D"
              BorderThickness="1"
              CornerRadius="8">
        <StackPanel>

          <!-- Toggle Header -->
          <Button Command="{Binding ToggleTagsCommand}"
                  Background="Transparent"
                  BorderThickness="0"
                  Padding="16,12"
                  HorizontalAlignment="Stretch"
                  HorizontalContentAlignment="Stretch">
            <Grid ColumnDefinitions="*,Auto">
              <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                <TextBlock Text="🏷"
                           FontSize="16"
                           VerticalAlignment="Center"/>
                <TextBlock Text="Customize Tags"
                           FontSize="14"
                           FontWeight="SemiBold"
                           Foreground="#F0F0F0"
                           VerticalAlignment="Center"/>
                <Border Background="#3A3A3A"
                        CornerRadius="10"
                        Padding="6,2">
                  <TextBlock Text="{Binding Tags.Count}"
                             FontSize="12"
                             Foreground="#AAAAAA"/>
                </Border>
              </StackPanel>
              <TextBlock Grid.Column="1"
                         Text="{Binding TagsExpanded}"
                         FontSize="16"
                         Foreground="#666666"
                         VerticalAlignment="Center"/>
            </Grid>
          </Button>

          <!-- Expanded Tag Area -->
          <StackPanel IsVisible="{Binding TagsExpanded}"
                      Margin="16,0,16,16"
                      Spacing="12">

            <Rectangle Height="1" Fill="#3D3D3D" Margin="0,0,0,4"/>

            <!-- Existing Tags -->
            <ItemsControl ItemsSource="{Binding Tags}">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Grid ColumnDefinitions="*,12,*,Auto" Margin="0,0,0,8">
                    <TextBox Grid.Column="0"
                             Text="{Binding Identifier}"
                             Watermark="Identifier"
                             Background="#2B2B2B"
                             Foreground="#F0F0F0"
                             BorderBrush="#3D3D3D"
                             BorderThickness="1"
                             CornerRadius="6"
                             Padding="10,8"
                             FontSize="13"/>
                    <TextBlock Grid.Column="1"
                               Text="→"
                               Foreground="#555555"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Center"
                               FontSize="14"/>
                    <TextBox Grid.Column="2"
                             Text="{Binding Data}"
                             Watermark="Value"
                             Background="#2B2B2B"
                             Foreground="#F0F0F0"
                             BorderBrush="#3D3D3D"
                             BorderThickness="1"
                             CornerRadius="6"
                             Padding="10,8"
                             FontSize="13"/>
                    <Button Grid.Column="3"
                            Command="{Binding $parent[UserControl].DataContext.RemoveTagCommand}"
                            CommandParameter="{Binding}"
                            Background="Transparent"
                            BorderThickness="0"
                            Foreground="#666666"
                            Padding="8,4"
                            Margin="4,0,0,0"
                            Content="✕"
                            FontSize="14"/>
                  </Grid>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Add Tag Button -->
            <Button Command="{Binding AddTagCommand}"
                    Background="#2B2B2B"
                    BorderBrush="#3D3D3D"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="12,8"
                    HorizontalAlignment="Left">
              <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="+"
                           FontSize="16"
                           Foreground="#7B68EE"
                           VerticalAlignment="Center"/>
                <TextBlock Text="Add Tag"
                           FontSize="13"
                           Foreground="#AAAAAA"
                           VerticalAlignment="Center"/>
              </StackPanel>
            </Button>

          </StackPanel>
        </StackPanel>
      </Border>

      <!-- Submit -->
      <Button Command="{Binding PublishCommand}"
              HorizontalAlignment="Stretch"
              HorizontalContentAlignment="Center"
              Background="#7B68EE"
              Foreground="#FFFFFF"
              BorderThickness="0"
              CornerRadius="8"
              Padding="0,14"
              FontSize="15"
              FontWeight="SemiBold"
              Content="Publish Event"/>

    </StackPanel>
  </ScrollViewer>
</UserControl>
