<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:N0str.ViewModels.Pages"
             xmlns:nostr="clr-namespace:NNostr.Client;assembly=NNostr.Client"
             x:DataType="vm:FeedViewModel"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
             x:Class="N0str.Views.Pages.FeedView"
             Background="#141414">

  <UserControl.Styles>
    <!-- Event card hover -->
    <Style Selector="Border.event-card:pointerover">
      <Setter Property="BorderBrush" Value="#333333"/>
    </Style>
  </UserControl.Styles>

  <Grid RowDefinitions="Auto,Auto,*">

    <!-- Header -->
    <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto" Margin="28,24,28,0">
      <Button Grid.Column="0"
              Command="{Binding BackCommand}"
              Background="#1C1C1C"
              BorderBrush="#2A2A2A"
              BorderThickness="1"
              CornerRadius="8"
              Padding="14,7"
              FontSize="13"
              Foreground="#888888"
              VerticalAlignment="Center">
        <StackPanel Orientation="Horizontal" Spacing="6">
          <TextBlock Text="←" FontSize="13" Foreground="#888888" VerticalAlignment="Center"/>
          <TextBlock Text="Back" FontSize="13" Foreground="#888888" VerticalAlignment="Center"/>
        </StackPanel>
      </Button>

      <StackPanel Grid.Column="1" Margin="14,0,0,0" VerticalAlignment="Center">
        <TextBlock Text="Event Feed"
                   FontSize="20"
                   FontWeight="SemiBold"
                   Foreground="#F2F2F2"
                   LetterSpacing="-0.3"/>
        <TextBlock Text="{Binding Pubkey}"
                   FontSize="11"
                   Foreground="#555555"
                   Margin="0,2,0,0"/>
      </StackPanel>

      <!-- Live indicator -->
      <StackPanel Grid.Column="2"
                  Orientation="Horizontal"
                  Spacing="6"
                  VerticalAlignment="Center"
                  IsVisible="{Binding !IsLoading}">
        <Ellipse Width="6" Height="6" Fill="#4CAF50"/>
        <TextBlock Text="LIVE"
                   FontSize="11"
                   Foreground="#4CAF50"
                   VerticalAlignment="Center"/>
      </StackPanel>
    </Grid>

    <!-- Divider -->
    <Rectangle Grid.Row="1" Height="1" Fill="#1E1E1E" Margin="28,16,28,16"/>

    <!-- Loading state -->
    <StackPanel Grid.Row="2"
                IsVisible="{Binding IsLoading}"
                VerticalAlignment="Center"
                HorizontalAlignment="Center"
                Spacing="16">
      <!-- Spinner via rotating border -->
      <Border Width="32" Height="32"
              BorderThickness="2"
              BorderBrush="#7B68EE"
              CornerRadius="16">
        <Border.RenderTransform>
          <RotateTransform/>
        </Border.RenderTransform>
        <Border.Transitions>
          <Transitions>
            <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.8"/>
          </Transitions>
        </Border.Transitions>
      </Border>
      <TextBlock Text="Fetching events..."
                 FontSize="12"
                 Foreground="#444444"
                 HorizontalAlignment="Center"/>
    </StackPanel>

    <!-- Events list -->
    <ScrollViewer Grid.Row="2"
                  IsVisible="{Binding !IsLoading}"
                  Padding="28,0,28,28">
      <ItemsControl ItemsSource="{Binding Events}">
        <ItemsControl.ItemTemplate>
          <DataTemplate x:DataType="nostr:NostrEvent">
            <Border Classes="event-card"
                    Background="#1C1C1C"
                    BorderBrush="#252525"
                    BorderThickness="1"
                    CornerRadius="12"
                    Padding="18,16"
                    Margin="0,0,0,10">
              <StackPanel Spacing="12">

                <!-- Meta row: kind + timestamp -->
                <Grid ColumnDefinitions="Auto,*,Auto">
                  <Border Grid.Column="0"
                          Background="#252525"
                          BorderBrush="#2E2E2E"
                          BorderThickness="1"
                          CornerRadius="20"
                          Padding="10,3">
                    <TextBlock Text="{Binding Kind, StringFormat='kind:\{0\}'}"
                               FontSize="10"
                               Foreground="#7B68EE"/>
                  </Border>
                  <TextBlock Grid.Column="2"
                             Text="{Binding CreatedAt, StringFormat='\{0:yyyy-MM-dd · HH:mm\}'}"
                             FontSize="11"
                             Foreground="#444444"
                             VerticalAlignment="Center"/>
                </Grid>

                <!-- Content -->
                <TextBlock Text="{Binding Content}"
                           FontSize="14"
                           FontWeight="Light"
                           Foreground="#D0D0D0"
                           TextWrapping="Wrap"
                           LineHeight="22"/>

                <!-- Tags -->
                <ItemsControl ItemsSource="{Binding Tags}"
                              IsVisible="{Binding Tags.Count, Converter={x:Static ObjectConverters.IsNotNull}}">
                  <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                      <WrapPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                  </ItemsControl.ItemsPanel>
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <Border Background="#1A1A2E"
                              BorderBrush="#2A2A4A"
                              BorderThickness="1"
                              CornerRadius="6"
                              Padding="9,3"
                              Margin="0,0,6,6">
                        <TextBlock FontSize="11"
                                   Foreground="#7B68EEaa">
                          <Run Text="#" Foreground="#555555"/>
                          <Run Text="{Binding TagIdentifier}"/>
                          <Run Text=" · " Foreground="#333333"/>
                          <Run Text="{Binding Data[0], FallbackValue=''}" Foreground="#7B68EE88"/>
                        </TextBlock>
                      </Border>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>

              </StackPanel>
            </Border>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </ScrollViewer>

  </Grid>
</UserControl>