<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:N0str.ViewModels.Pages"
             xmlns:nostr="clr-namespace:NNostr.Client;assembly=NNostr.Client"
             x:DataType="vm:FeedViewModel"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
             x:Class="N0str.Views.Pages.FeedView"
             Background="#141414">

  <Grid RowDefinitions="Auto,Auto,*">

    <!-- Header -->
    <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto" Margin="28,24,28,0">
      <Button Grid.Column="0"
              Command="{Binding BackCommand}"
              Background="#1C1C1C"
              BorderBrush="#2A2A2A"
              BorderThickness="1"
              CornerRadius="8"
              Padding="14,7"
              FontSize="13"
              Foreground="#888888"
              VerticalAlignment="Center">
        <StackPanel Orientation="Horizontal" Spacing="6">
          <TextBlock Text="←" FontSize="13" Foreground="#888888" VerticalAlignment="Center"/>
          <TextBlock Text="Back" FontSize="13" Foreground="#888888" VerticalAlignment="Center"/>
        </StackPanel>
      </Button>

      <StackPanel Grid.Column="1" Margin="14,3,0,0" VerticalAlignment="Center">
        <TextBlock Text="Event Feed"
                   FontSize="20"
                   FontWeight="SemiBold"
                   Foreground="#F2F2F2"
                   LetterSpacing="-0.3"/>
      </StackPanel>

      <!-- Add new Sub button -->
      <StackPanel Grid.Column="2"
                  Orientation="Horizontal"
                  Spacing="6"
                  VerticalAlignment="Center"
                  IsVisible="{Binding !IsLoading}">
        <Button Command="{Binding AddNewSubCommand}"
                Content="Add new Sub"
                Background="#F2F2F2"
                BorderBrush="#2A2A2A"
                BorderThickness="1"
                CornerRadius="8"
                Padding="14,7"
                FontSize="13"
                Foreground="#888888"
                VerticalAlignment="Center">
        </Button>
      </StackPanel>
    </Grid>

    <!-- Divider -->
    <Rectangle Grid.Row="1" Height="1" Fill="#1E1E1E" Margin="28,16,28,16"/>

    <!-- Loading state -->
    <StackPanel Grid.Row="2"
                IsVisible="{Binding IsLoading}"
                VerticalAlignment="Center"
                HorizontalAlignment="Center"
                Spacing="16">
      <!-- Spinner via rotating border -->
      <Border Width="32" Height="32"
              BorderThickness="2"
              BorderBrush="#7B68EE"
              CornerRadius="16">
        <Border.RenderTransform>
          <RotateTransform/>
        </Border.RenderTransform>
        <Border.Transitions>
          <Transitions>
            <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.8"/>
          </Transitions>
        </Border.Transitions>
      </Border>
      <TextBlock Text="Fetching events..."
                 FontSize="12"
                 Foreground="#444444"
                 HorizontalAlignment="Center"/>
    </StackPanel>

    <!-- Events list -->
    <ScrollViewer Grid.Row="2"
                  IsVisible="{Binding !IsLoading}"
                  Padding="28,0,28,28">
      <ItemsControl ItemsSource="{Binding Events}" />
    </ScrollViewer>

  </Grid>
</UserControl>